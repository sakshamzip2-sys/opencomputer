{
  "id": "anthropic-provider",
  "name": "Anthropic Provider",
  "version": "0.1.0",
  "description": "Anthropic Claude models — supports native x-api-key and Bearer-auth proxies (Claude Router etc.)",
  "author": "Saksham",
  "license": "MIT",
  "kind": "provider",
  "entry": "plugin",
  "tool_names": [],
  "min_host_version": "2026.1.1",
  "model_support": {
    "model_prefixes": ["claude-"]
  },
  "activation": {
    "on_providers": ["anthropic"],
    "on_models": ["claude-"]
  },
  "setup": {
    "providers": [
      {
        "id": "anthropic",
        "auth_methods": ["api_key", "bearer"],
        "env_vars": ["ANTHROPIC_API_KEY"],
        "label": "Anthropic (Claude)",
        "default_model": "claude-opus-4-7",
        "signup_url": "https://console.anthropic.com/settings/keys"
      }
    ]
  }
}
