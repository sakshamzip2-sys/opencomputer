# Example .env for the memory-honcho plugin.
# Copy to ~/.opencomputer/honcho/.env (or export vars directly) and edit.

# Base URL of the self-hosted Honcho service. The bundled docker-compose
# (Phase 10f.M) binds to 127.0.0.1:8000 by default.
HONCHO_BASE_URL=http://localhost:8000

# API key. Leave empty for self-hosted no-auth mode (compose-local only).
HONCHO_API_KEY=

# Workspace + host_key — Honcho's namespace for this OpenComputer install.
# Phase 14.J will override HONCHO_HOST_KEY to opencomputer.<profile> when
# a non-default profile is active, so each profile gets its own AI peer
# model while sharing the same user identity.
HONCHO_WORKSPACE=opencomputer
HONCHO_HOST_KEY=opencomputer

# Cadence tuning. Default: prefetch every turn, sync every 3rd turn.
HONCHO_CONTEXT_CADENCE=1
HONCHO_DIALECTIC_CADENCE=3
