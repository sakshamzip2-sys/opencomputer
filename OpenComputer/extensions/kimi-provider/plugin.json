{
  "id": "kimi-provider",
  "name": "Kimi (Moonshot)",
  "kind": "provider",
  "version": "0.1.0",
  "entry": "plugin",
  "description": "Kimi / Moonshot — OpenAI-compatible direct API.",
  "model_support": {
    "model_prefixes": ["moonshot-", "kimi-"]
  },
  "setup": {
    "providers": [
      {
        "id": "kimi",
        "auth_methods": ["api_key"],
        "env_vars": ["MOONSHOT_API_KEY"],
        "label": "Kimi / Moonshot (direct API)",
        "default_model": "moonshot-v1-128k",
        "signup_url": "https://platform.moonshot.ai/console/api-keys"
      }
    ]
  }
}
