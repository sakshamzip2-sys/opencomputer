{
  "name": "opencomputer-browser-control-extension",
  "version": "0.6.0",
  "description": "Active control bridge for the OpenComputer agent. Drives Chrome tabs via chrome.debugger over a localhost WebSocket.",
  "private": true,
  "scripts": {
    "build": "esbuild src/background.ts --bundle --format=esm --target=chrome120 --outfile=dist/background.js --define:__OPENCOMPUTER_COMPAT_RANGE__=\\\"^0.6.0\\\"",
    "watch": "esbuild src/background.ts --bundle --format=esm --target=chrome120 --outfile=dist/background.js --define:__OPENCOMPUTER_COMPAT_RANGE__=\\\"^0.6.0\\\" --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.290",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
