# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/

# Exception: the dashboard SPA's `lib/` is TypeScript source, not the
# Python packaging build artifact above. Without this re-include,
# git silently ignores ui-web/src/lib/api.ts + wire.ts + events.ts
# (caught 2026-05-07 when CI failed loading "@/lib/api").
!ui-web/src/lib/
!ui-web/src/lib/**
# Same exception for the TUI's `lib/` (TypeScript helpers like
# themeDetect.ts) — caught 2026-05-08 when Hermes-parity D1 source was
# silently ignored.
!ui-tui/src/lib/
!ui-tui/src/lib/**

# Frontend build artifacts (produced by `cd ui-web && npm run build` /
# `cd ui-tui && npm run build`). Excluded from git but force-included
# in the wheel via pyproject.toml [tool.hatch.build.targets.wheel.force-include].
#
# The trailing-slash variants only match real directories. The
# scripts/bootstrap_worktree.sh helper creates SYMLINKS at the same
# paths so fresh git worktrees can run `uv tool install --editable .`
# without first building the SPA / TUI; the non-trailing-slash variants
# (added 2026-05-12) keep those symlinks out of `git status`.
opencomputer/dashboard/static/spa/
opencomputer/dashboard/static/spa
opencomputer/ui-tui/dist/
opencomputer/ui-tui/dist
opencomputer/ui-tui
ui-tui/dist/
ui-tui/packages/*/dist/

# Node ecosystem
**/node_modules/
ui-web/public/fonts/
ui-web/public/ds-assets/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# uv
.uv-cache/

