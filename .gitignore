# Reference repos cloned for study — not part of OpenComputer.
# Anchor with leading slash so this only matches the top-level sources/ dir,
# not arbitrary subpackages named 'sources/' inside OpenComputer.
/sources/

# OS
.DS_Store

# Git worktrees
/.worktrees/

# Python virtualenvs within subprojects
**/.venv/
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/*.egg-info/
**/dist/
**/build/

# Node — added 2026-05-10 when browser-harness + opencli-bridge plugins
# introduced project-local npm deps. We commit package.json + package-lock.json
# (the manifest + exact version pins for reproducibility) but ignore the
# materialised node_modules tree (GBs of transitive deps, regenerable via
# `npm install`).
**/node_modules/
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Claude Code per-session artifacts (transcripts, memory, etc.) live
# alongside the repo but shouldn't be tracked.
/.claude/

# Nested git checkouts living inside the parent repo for local experiments
# / vendored UIs. They have their own remotes and PR flows — committing
# them as embedded repos would shadow .gitmodules-style submodule semantics
# without any of the tracking. (oc-workspace was consolidated into this
# monorepo on 2026-05-15 — it is now tracked here directly, not ignored.)
/claude-plugins-official/
/open-design/

# Playwright MCP browser cache + Finder-style duplicate work dirs.
.playwright-mcp/
/design_handoff_prompt_bar 2/
